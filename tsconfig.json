{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "allowJs": false,
    "noEmit": true,
    "incremental": true,
    "plugins": [{ "name": "next" }]
  },
  "include": [
    "next-env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "apps/web/**/*.ts",
    "apps/web/**/*.tsx",
    "packages/shared/src/**/*.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", "apps/**/node_modules", "packages/**/node_modules"]
}
