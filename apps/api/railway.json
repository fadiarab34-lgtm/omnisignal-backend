{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter @omnisignal/shared build && pnpm --filter @omnisignal/market-connectors build && pnpm --filter @omnisignal/ai build && pnpm --filter @omnisignal/trading build && pnpm --filter @omnisignal/api build",
    "watchPatterns": [
      "/apps/api/**",
      "/packages/shared/**",
      "/packages/market-connectors/**",
      "/packages/ai/**",
      "/packages/trading/**",
      "/package.json",
      "/pnpm-lock.yaml",
      "/pnpm-workspace.yaml",
      "/turbo.json"
    ]
  },
  "deploy": {
    "preDeployCommand": "pnpm --filter @omnisignal/api prisma:migrate",
    "startCommand": "pnpm --filter @omnisignal/api start",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
